# SIGAP Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Google AI Studio API Keys
# Get free keys at: https://aistudio.google.com/apikey
# Each agent has its own key to avoid quota conflicts.
# If an agent-specific key is missing, it falls back to GOOGLE_API_KEY.
GOOGLE_API_KEY=your_default_key_here
GOOGLE_API_KEY_MONITOR=your_monitor_key_here
GOOGLE_API_KEY_ASSESSMENT=your_assessment_key_here
GOOGLE_API_KEY_COORDINATOR=your_coordinator_key_here
GOOGLE_API_KEY_ORCHESTRATOR=your_orchestrator_key_here

# App Settings
APP_ENV=development
APP_SECRET_KEY=change_this_to_a_random_secret_string

# JWT Settings
JWT_SECRET=change_this_to_another_random_string
JWT_ALGORITHM=HS256

JWT_EXPIRE_MINUTES=60

# SQLite DB path
DATABASE_URL=sqlite+aiosqlite:///./sigap.db

# BMKG API (public, no key needed)
BMKG_BASE_URL=https://data.bmkg.go.id/DataMKG/TEWS

# Gemini Model (gemini-2.0-flash and older are shut down as of June 1 2026)
GEMINI_MODEL=gemini-3.1-flash-lite
